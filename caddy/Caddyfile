{
    auto_https off
    admin localhost:2019
}

# Dashboard + API (only matches localhost, not deployment subdomains)
localhost:80 {
    # Health check
    header /health Content-Type "application/json"
    respond /health 200 `{"status":"ok","service":"caddy"}`

    # Proxy API requests
    handle /api/* {
        reverse_proxy api:3000
    }

    # Proxy webhooks
    handle /webhooks/* {
        reverse_proxy api:3000
    }

    # Default fallback — proxy to API (serves dashboard at /)
    handle {
        reverse_proxy api:3000
    }
}

# Include generated deployment configs (must be at top level)
import /app/caddy/configs/*.caddy
