{
    auto_https off
    admin localhost:2019
}

:80 {
    # Health check
    header /health Content-Type "application/json"
    respond /health 200 `{"status":"ok","service":"caddy"}`

    # Proxy API requests
    handle /api/* {
        reverse_proxy api:3000
    }

    # Proxy webhooks
    handle /webhooks/* {
        reverse_proxy api:3000
    }

    # Include generated deployment configs
    import /app/caddy/configs/*.caddy

    # Default fallback — proxy to API (serves dashboard at /)
    handle {
        reverse_proxy api:3000
    }
}
