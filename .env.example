# ── Server ─────────────────────────────────────────────────────
PORT=3000

# ── PostgreSQL ───────────────────────────────────────────────
DATABASE_URL=postgres://vercel_clone:vercel_clone@localhost:5432/vercel_clone

# ── NATS JetStream ────────────────────────────────────────────
NATS_URL=nats://localhost:4222
NATS_STREAM_NAME=BUILDS
NATS_CONSUMER_NAME=build-workers

# ── S3 / MinIO Object Storage ─────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=vercel-artifacts
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1

# ── GitHub ────────────────────────────────────────────────────
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=your-webhook-secret-here
GITHUB_TOKEN=

# ── Platform ──────────────────────────────────────────────────
BASE_DOMAIN=localhost
DOCKER_BUILD_IMAGE=node:20-slim
BUILD_MEMORY_LIMIT=2147483648
BUILD_TIMEOUT_SECS=600

# ── Edge / Serving ────────────────────────────────────────────
CADDY_CONFIG_DIR=./caddy/configs
ARTIFACTS_DIR=./artifacts

# ── Scaling ────────────────────────────────────────────────────
MAX_CONCURRENT_BUILDS=4
WARM_POOL_SIZE=2

# ── Logging ───────────────────────────────────────────────────
RUST_LOG=vercel_clone=debug,tower_http=debug
